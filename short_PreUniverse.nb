Cell[CellGroupData[{

Cell["\<\
(* ---- Verify all Gell-Mann generators commute with J ---- *)

Print[\"Verifying all lambda_k commute with J (required for u(3) action on \
C^3):\"];
Do[
  comm = lam[[k]] . J6 - J6 . lam[[k]];
  Print[\"[lambda_\", k, \", J] = 0: \", If[comm == 0*J6, \"VERIFIED\", \
\"ERROR - does not commute with J\"]];
, {k, 1, 8}];\
\>", "Input",
