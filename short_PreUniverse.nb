Cell[CellGroupData[{

Cell["\<\
(* ---- Numerical example ---- *)

(* Choose explicit unit vectors v1, v2 in R^8 (generic position) *)
(* v1 and v2 should be independent and have non-zero \[Eta]88-norms *)
v1num = {1,0,0,0,0,0,0,0};   (* e0 direction: \[Eta]88-norm +1 *)
v2num = {0,1,0,0,0,0,0,0};   (* e1 direction: \[Eta]88-norm +1 *)

n1num = \[Eta]88 . v1num;
n2num = \[Eta]88 . v2num;
normalMatrixNum = {n1num, n2num};

(* sixPlaneAlpha as explicit 6x8 basis matrix (rows are basis vectors) *)
sixPlaneAlphaBasis = NullSpace[normalMatrixNum];
Print[\"sixPlaneAlpha basis (\" <> ToString[Length[sixPlaneAlphaBasis]] <> \" \
vectors in R^8):\"];
Print[MatrixForm[sixPlaneAlphaBasis]];
Print[\"Dimension of sixPlaneAlpha: \", Length[sixPlaneAlphaBasis]];\
\>", "Input",
 CellChangeTimes->{{3.9835961844647207`*^9, 3.9835961844748783`*^9}},
 CellLabel->
  "In[160]:=",ExpressionUUID->"48ca6138-746a-4d18-ba42-79fc904bf6c5"],

