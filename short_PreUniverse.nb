Cell[CellGroupData[{

Cell["\<\


(* Symbolic normal vectors v1, v2 in R^8 (image of chiral spinors under \
triality) *)
Clear[v1s,v1,v2s,v2]
v1s = Array[Subscript[v1,#]&, 8];
v2s = Array[Subscript[v2,#]&, 8];

(* The two 7-planes H1, H2 are defined by the vanishing of \[Eta]88-inner \
products *)
(* H1 = {x : x.\[Eta]88.v1 = 0},  H2 = {x : x.\[Eta]88.v2 = 0} *)
(* Normal covectors in the dual space *)
n1 = \[Eta]88 . v1s;
n2 = \[Eta]88 . v2s;

(* sixPlaneAlpha = H1 intersect H2 = NullSpace of normalMatrix *)
normalMatrix = {n1, n2};
Print[\"Normal matrix (2x8) whose null space is sixPlaneAlpha:\"];
Print[MatrixForm[normalMatrix]];\
\>", "Input",
 CellChangeTimes->{{3.983564611909197*^9, 3.983564629742622*^9}, {
   3.983564693059713*^9, 3.9835647300403767`*^9}, 3.983595963583832*^9, {
   3.98359618445083*^9, 3.983596184461892*^9}},
 CellLabel->
  "In[143]:=",ExpressionUUID->"7076df76-949b-41ec-8d2d-0e0ad38d7f03"],

