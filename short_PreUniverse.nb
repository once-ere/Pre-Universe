Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "dualRawSets", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dualRawSets", "[", 
   RowBox[{"l_", ",", "f_", ",", "o_", ",", "h_", ",", "oh_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", ",", "r1", ",", "r2"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"r1", "=", 
      RowBox[{"rawSets", "[", 
       RowBox[{"l", ",", "f", ",", "o"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"r2", "=", 
      RowBox[{"rawSets", "[", 
       RowBox[{"l", ",", "h", ",", "oh"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"r", "=", 
      RowBox[{
       RowBox[{"Union", "[", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"r1", ",", "r2"}], "}"}], ",", "1"}], "]"}], "]"}], "//", 
       RowBox[{
        RowBox[{"Drop", "[", 
         RowBox[{"#", ",", "1"}], "]"}], "&"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "r", "]"}], ";"}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
