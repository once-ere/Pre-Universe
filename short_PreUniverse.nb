     RowBox[{"t", "=", 
      RowBox[{
       RowBox[{"Table", "[", 
        RowBox[{
         RowBox[{"Block", "[", 
          RowBox[{
           RowBox[{"{", 
            RowBox[{"F", ",", "s"}], "}"}], ",", 
           RowBox[{
            RowBox[{"F", "=", 
             RowBox[{"\[CapitalPsi]16", "[", 
              RowBox[{"[", "k", "]"}], "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"s", "=", 
             RowBox[{
              RowBox[{"D", "[", 
               RowBox[{"L", ",", "F"}], "]"}], "-", 
              RowBox[{"Sum", "[", " ", 
               RowBox[{
                RowBox[{"Block", "[", 
                 RowBox[{
                  RowBox[{"{", 
                   RowBox[{"x", ",", "y", ",", "p", ",", "q"}], "}"}], ",", 
                  "\[IndentingNewLine]", 
