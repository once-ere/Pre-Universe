                   RowBox[{"x", "=", 
                    RowBox[{"X", "[", 
                    RowBox[{"[", "\[Alpha]1", "]"}], "]"}]}], ";", 
                   "\[IndentingNewLine]", 
                   RowBox[{"y", "=", 
                    RowBox[{"D", "[", 
                    RowBox[{"F", ",", "x"}], "]"}]}], ";", 
                   "\[IndentingNewLine]", 
                   RowBox[{"p", "=", 
                    RowBox[{"D", "[", 
                    RowBox[{"L", ",", "y"}], "]"}]}], ";", 
                   "\[IndentingNewLine]", 
                   RowBox[{"q", "=", 
                    RowBox[{"D", "[", 
                    RowBox[{"p", ",", "x"}], "]"}]}], ";", 
                   "\[IndentingNewLine]", "q"}]}], "]"}], ",", 
                RowBox[{"{", 
                 RowBox[{"\[Alpha]1", ",", "1", ",", 
                  RowBox[{"Length", "[", "X", "]"}]}], "}"}]}], "]"}]}]}], ";",
             "\[IndentingNewLine]", "s"}]}], "]"}], "\[IndentingNewLine]", ",", 
         RowBox[{"{", 
          RowBox[{"k", ",", "1", ",", 
           RowBox[{"Length", "[", "\[CapitalPsi]16", "]"}]}], "}"}]}], "]"}], 
