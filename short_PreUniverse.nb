Cell[BoxData[
 RowBox[{
  SuperscriptBox["expr_", "*"], ":=", " ", 
  RowBox[{"expr", "/.", 
   RowBox[{
    RowBox[{"Complex", "[", 
     RowBox[{"a_", ",", "b_"}], "]"}], "\[RuleDelayed]", 
    RowBox[{"Complex", "[", 
     RowBox[{"a", ",", 
      RowBox[{"-", "b"}]}], "]"}]}]}]}]], "Input",
 CellLabel->"In[11]:=",ExpressionUUID->"6e5f9888-79dc-43c0-af64-e0a2838f0242"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ra", "[", "z_", "]"}], ":=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{"z", "+", 
     RowBox[{"(", 
      RowBox[{"z", "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Complex", "[", 
          RowBox[{"a_", ",", "b_"}], "]"}], "\[RuleDelayed]", 
         RowBox[{"Complex", "[", 
          RowBox[{"a", ",", 
           RowBox[{"-", "b"}]}], "]"}]}], "}"}]}], ")"}]}], 
    ")"}]}]}]], "Input",
 CellLabel->"In[12]:=",ExpressionUUID->"815ecac8-1264-4787-b753-098368da975d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ia", "[", "z_", "]"}], ":=", 
  RowBox[{
   FractionBox["1", 
    RowBox[{"2", " ", "\[ImaginaryI]"}]], 
   RowBox[{"(", 
    RowBox[{"z", "-", 
     RowBox[{"(", 
      RowBox[{"z", "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Complex", "[", 
          RowBox[{"a_", ",", "b_"}], "]"}], "\[RuleDelayed]", 
         RowBox[{"Complex", "[", 
          RowBox[{"a", ",", 
           RowBox[{"-", "b"}]}], "]"}]}], "}"}]}], ")"}]}], 
    ")"}]}]}]], "Input",
 CellChangeTimes->{{3.9751824426833763`*^9, 3.9751824630105534`*^9}},
 CellLabel->"In[13]:=",ExpressionUUID->"fcb04d6c-ff53-48d5-97e5-0aeaa4572aa3"],

