Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Helper", " ", "to", " ", "perform", " ", "one", " ", "pass", " ", "of", " ",
     "merging"}], " ", "*)"}], "\n", 
  RowBox[{
   RowBox[{
    RowBox[{"MergeSetsStep", "[", "currentSets_List", "]"}], " ", ":=", " ", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{
        RowBox[{"n", " ", "=", " ", 
         RowBox[{"Length", "[", "currentSets", "]"}]}], ",", " ", "i", ",", 
        " ", "j", ",", " ", 
        RowBox[{"merged", " ", "=", " ", "currentSets"}]}], "}"}], ",", "\n", 
      "  ", 
      RowBox[{"(*", " ", 
       RowBox[{
       "We", " ", "look", " ", "for", " ", "the", " ", "first", " ", "pair", " ", 
        RowBox[{"(", 
         RowBox[{"i", ",", " ", "j"}], ")"}], " ", "that", " ", 
        "intersects"}], " ", "*)"}], "\n", "  ", 
      RowBox[{"Catch", "[", "\n", "    ", 
       RowBox[{
        RowBox[{"For", "[", 
         RowBox[{
          RowBox[{"i", " ", "=", " ", "1"}], ",", " ", 
          RowBox[{"i", " ", "<=", " ", 
           RowBox[{"Length", "[", "merged", "]"}]}], ",", " ", 
          RowBox[{"i", "++"}], ",", "\n", "      ", 
          RowBox[{
           RowBox[{"For", "[", 
            RowBox[{
             RowBox[{"j", " ", "=", " ", 
              RowBox[{"i", " ", "+", " ", "1"}]}], ",", " ", 
             RowBox[{"j", " ", "<=", " ", 
              RowBox[{"Length", "[", "merged", "]"}]}], ",", " ", 
             RowBox[{"j", "++"}], ",", "\n", "         ", 
             RowBox[{
              RowBox[{"If", "[", 
               RowBox[{
                RowBox[{
                 RowBox[{"Intersection", "[", 
                  RowBox[{
                   RowBox[{"merged", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], ",", " ", 
                   RowBox[{"merged", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], "]"}], " ", "=!=", " ", 
                 
                 RowBox[{"{", "}"}]}], ",", "\n", "            ", 
                RowBox[{"(*", " ", 
                 RowBox[{"Found", " ", 
                  RowBox[{"intersection", ":", " ", 
                   RowBox[{
                   "Merge", " ", "and", " ", "Throw", " ", "to", " ", 
                    RowBox[{"restart", "/", "finish"}], " ", "this", " ", 
                    "step"}]}]}], " ", "*)"}], "\n", "            ", 
                RowBox[{
