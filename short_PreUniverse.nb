Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "dualRawSets", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"dualRawSets", "[", 
   RowBox[{"l_", ",", "f_", ",", "o_", ",", "h_", ",", "oh_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"r", ",", "r1", ",", "r2"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"r1", "=", 
      RowBox[{"rawSets", "[", 
       RowBox[{"l", ",", "f", ",", "o"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"r2", "=", 
      RowBox[{"rawSets", "[", 
       RowBox[{"l", ",", "h", ",", "oh"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"r", "=", 
      RowBox[{
       RowBox[{"Union", "[", 
        RowBox[{"Flatten", "[", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"r1", ",", "r2"}], "}"}], ",", "1"}], "]"}], "]"}], "//", 
       RowBox[{
        RowBox[{"Drop", "[", 
         RowBox[{"#", ",", "1"}], "]"}], "&"}]}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "r", "]"}], ";"}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
 CellChangeTimes->{{3.9788876703367844`*^9, 3.978887871152401*^9}},
 CellLabel->"In[19]:=",ExpressionUUID->"5a1c4523-8118-4dda-b02b-dac892a87d21"],

