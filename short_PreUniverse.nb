Cell[BoxData[
 RowBox[{
  SuperscriptBox["expr_", "*"], ":=", " ", 
  RowBox[{"expr", "/.", 
   RowBox[{
    RowBox[{"Complex", "[", 
     RowBox[{"a_", ",", "b_"}], "]"}], "\[RuleDelayed]", 
    RowBox[{"Complex", "[", 
     RowBox[{"a", ",", 
      RowBox[{"-", "b"}]}], "]"}]}]}]}]], "Input",
 CellLabel->
  "In[168]:=",ExpressionUUID->"6e5f9888-79dc-43c0-af64-e0a2838f0242"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ra", "[", "z_", "]"}], ":=", 
  RowBox[{
   FractionBox["1", "2"], 
   RowBox[{"(", 
    RowBox[{"z", "+", 
     RowBox[{"(", 
      RowBox[{"z", "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Complex", "[", 
          RowBox[{"a_", ",", "b_"}], "]"}], "\[RuleDelayed]", 
         RowBox[{"Complex", "[", 
          RowBox[{"a", ",", 
           RowBox[{"-", "b"}]}], "]"}]}], "}"}]}], ")"}]}], 
    ")"}]}]}]], "Input",
 CellLabel->
  "In[169]:=",ExpressionUUID->"815ecac8-1264-4787-b753-098368da975d"],

Cell[BoxData[
 RowBox[{
  RowBox[{"ia", "[", "z_", "]"}], ":=", 
  RowBox[{
   FractionBox["1", 
    RowBox[{"2", " ", "\[ImaginaryI]"}]], 
   RowBox[{"(", 
    RowBox[{"z", "-", 
     RowBox[{"(", 
      RowBox[{"z", "/.", 
       RowBox[{"{", 
        RowBox[{
         RowBox[{"Complex", "[", 
          RowBox[{"a_", ",", "b_"}], "]"}], "\[RuleDelayed]", 
         RowBox[{"Complex", "[", 
          RowBox[{"a", ",", 
           RowBox[{"-", "b"}]}], "]"}]}], "}"}]}], ")"}]}], 
    ")"}]}]}]], "Input",
 CellChangeTimes->{{3.9751824426833763`*^9, 3.9751824630105534`*^9}},
 CellLabel->
  "In[170]:=",ExpressionUUID->"fcb04d6c-ff53-48d5-97e5-0aeaa4572aa3"],

Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "rawSets", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"rawSets", "[", 
   RowBox[{"l_", ",", "f_", ",", 
    RowBox[{"o_", ":", "0"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"t", ",", "h"}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"t", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Cases", "[", "\n", "   ", 
         RowBox[{
          RowBox[{"l", "[", 
           RowBox[{"[", "j", "]"}], "]"}], ",", " ", "\n", 
          RowBox[{
           RowBox[{
            RowBox[{"h_Symbol", "[", "n_Integer", "]"}], " ", "/;", " ", 
            RowBox[{"StringEndsQ", "[", 
             RowBox[{
              RowBox[{"SymbolName", "[", "h", "]"}], ",", " ", "f"}], "]"}]}],
            "  ", ":>", " ", 
           RowBox[{"n", "+", "o"}]}], ",", " ", "\n", "    ", "Infinity", ",",
           " ", "\n", "    ", 
          RowBox[{"Heads", " ", "->", " ", "True"}]}], "\n", "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", 
          RowBox[{"Length", "[", "l", "]"}]}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"Return", "[", "t", "]"}], ";"}]}], "\[IndentingNewLine]", 
   "]"}]}]}], "Input",
 CellChangeTimes->{
  3.978629231673209*^9, 3.978629472199901*^9, {3.9786295386192617`*^9, 
   3.9786295480868473`*^9}, 3.97862979070006*^9, {3.978635574787566*^9, 
