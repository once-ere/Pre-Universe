Cell[BoxData[
 RowBox[{
  RowBox[{"skelx", "[", 
   RowBox[{"x_", ",", 
    RowBox[{"matQ_", ":", "True"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"t", "=", 
      RowBox[{"{", "666", "}"}]}], "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"matQ", "\[Equal]", " ", "True"}], ",", 
       RowBox[{"t", "=", 
        RowBox[{"Block", "[", 
         RowBox[{
          RowBox[{"{", "r", "}"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"r", "=", "x"}], ";", "\[IndentingNewLine]", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"Block", "[", 
              RowBox[{
               RowBox[{"{", "q", "}"}], ",", 
               RowBox[{
                RowBox[{"q", "=", 
                 RowBox[{"SameQ", "[", 
                  RowBox[{"0", ",", 
                   RowBox[{"r", "[", 
                    RowBox[{"[", 
                    RowBox[{"j", ",", "i"}], "]"}], "]"}]}], "]"}]}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"True", "\[Equal]", " ", "q"}], ",", 
                  RowBox[{"Style", "[", 
                   RowBox[{"0", ",", "Blue"}], "]"}], ",", 
                  RowBox[{"Style", "[", 
                   RowBox[{
                    RowBox[{"Length", "[", 
                    RowBox[{"r", "[", 
                    RowBox[{"[", 
                    RowBox[{"j", ",", "i"}], "]"}], "]"}], "]"}], ",", 
                    "Red"}], "]"}]}], "]"}]}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", 
               RowBox[{"Length", "[", "r", "]"}]}], "}"}], ",", 
             RowBox[{"{", 
              RowBox[{"i", ",", "1", ",", 
               RowBox[{"Length", "[", 
                RowBox[{"r", "[", 
                 RowBox[{"[", 
                  RowBox[{"-", "1"}], "]"}], "]"}], "]"}]}], "}"}]}], 
            "]"}]}]}], "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{
       RowBox[{"matQ", "\[Equal]", " ", "False"}], ",", 
       RowBox[{"t", "=", 
        RowBox[{"Block", "[", 
         RowBox[{
          RowBox[{"{", "r", "}"}], ",", "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"r", "=", "x"}], ";", "\[IndentingNewLine]", 
           RowBox[{"Table", "[", 
            RowBox[{
             RowBox[{"Block", "[", 
              RowBox[{
               RowBox[{"{", "q", "}"}], ",", 
               RowBox[{
                RowBox[{"q", "=", 
                 RowBox[{"SameQ", "[", 
                  RowBox[{"0", ",", 
                   RowBox[{"r", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], "]"}]}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"If", "[", 
                 RowBox[{
                  RowBox[{"True", "\[Equal]", " ", "q"}], ",", 
                  RowBox[{"Style", "[", 
                   RowBox[{"0", ",", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"RGBColor", "\[Rule]", 
                    RowBox[{"{", 
                    RowBox[{"0", ",", 
                    RowBox[{"1", "/", "3"}], ",", "0"}], "}"}]}], ",", 
                    "Bold"}], "}"}]}], "]"}], ",", 
                  RowBox[{"Style", "[", 
                   RowBox[{
                    RowBox[{"Length", "[", 
                    RowBox[{"r", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "]"}], ",", "Red"}], 
                   "]"}]}], "]"}]}]}], "]"}], ",", 
             RowBox[{"{", 
              RowBox[{"j", ",", "1", ",", 
               RowBox[{"Length", "[", "r", "]"}]}], "}"}]}], "]"}]}]}], 
         "]"}]}]}], "]"}], ";", "\[IndentingNewLine]", 
     RowBox[{"MatrixForm", "[", 
      RowBox[{"t", ",", 
       RowBox[{"TableAlignments", "\[Rule]", "Left"}]}], "]"}]}]}], 
   "]"}]}]], "Input",
