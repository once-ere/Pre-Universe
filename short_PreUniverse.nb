 InterpretationBox[
  RowBox[{"\<\"J commutes with J (trivially): \"\>", 
   "\[InvisibleSpace]", "\<\"True\"\>"}],
  SequenceForm["J commutes with J (trivially): ", "True"],
  Editable->False]], "Print",
 CellChangeTimes->{3.983795033241665*^9, 3.983803972848311*^9, 
  3.983815459829197*^9},
