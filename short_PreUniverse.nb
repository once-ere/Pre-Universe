Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "safeInverse", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"safeInverse", "[", 
    RowBox[{"m_", "?", "MatrixQ"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a", ",", " ", "b"}], "}"}], ",", "\n", "   ", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a", ",", " ", "b"}], "}"}], " ", "=", " ", 
       RowBox[{"Dimensions", "[", "m", "]"}]}], ";", "\n", "    ", 
      RowBox[{"Catch", "[", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"a", " ", "!=", " ", "b"}], ",", " ", 
         RowBox[{"Throw", "[", 
          RowBox[{"Return", "[", 
           RowBox[{"{", 
            RowBox[{"a", ",", " ", "b"}], "}"}], "]"}], "]"}], ",", 
         RowBox[{
          RowBox[{"##", "&"}], "[", "]"}]}], "]"}], "]"}], ";", "\n", "   ", 
      RowBox[{"Catch", "[", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Det", "[", "m", "]"}], " ", "==", " ", "0"}], ",", " ", 
         RowBox[{
          RowBox[{"Throw", "[", 
           RowBox[{"Return", "[", "\"\<Error: Singular Matrix\>\"", "]"}], 
           "]"}], ";"}], ",", 
         RowBox[{
          RowBox[{"##", "&"}], "[", "]"}]}], "]"}], "]"}], ";", "\n", "   ", 
      RowBox[{"Return", "[", " ", 
       RowBox[{"Inverse", "[", "m", "]"}], "]"}], ";"}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.980334206576359*^9, 3.9803342114346867`*^9}, {
  3.9803343690658703`*^9, 3.9803344865101*^9}, {3.980353469994966*^9, 
  3.98035347350432*^9}},
 Background->RGBColor[0, 0.74, 0.74, 0.33],
 CellLabel->"In[24]:=",ExpressionUUID->"88299022-db11-4c91-8f2d-b522f759d7d2"],

Cell[BoxData[
 RowBox[{
  RowBox[{"blockPartition", "[", "mat_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"(*", 
      RowBox[{
      "blocks", ",", "block11", ",", "block12", ",", "block21", ",", 
       "block22", ","}], "*)"}], "ret", "}"}], ",", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{"blocks", "=", 
      RowBox[{"Partition", "[", 
       RowBox[{"mat", ",", 
        RowBox[{"{", 
         RowBox[{"8", ",", "8"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"block11", "=", 
        RowBox[{"blocks", "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "1"}], "]"}], "]"}]}], " ", ";"}], "*)"}], 
     RowBox[{"(*", 
      RowBox[{"Top", "-", 
       RowBox[{"left", " ", "block"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"block12", "=", 
        RowBox[{"blocks", "[", 
         RowBox[{"[", 
          RowBox[{"1", ",", "2"}], "]"}], "]"}]}], " ", ";"}], "*)"}], 
     RowBox[{"(*", 
      RowBox[{"Top", "-", 
       RowBox[{"right", " ", "block"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"block21", "=", 
        RowBox[{"blocks", "[", 
         RowBox[{"[", 
          RowBox[{"2", ",", "1"}], "]"}], "]"}]}], " ", ";"}], "*)"}], 
     RowBox[{"(*", 
      RowBox[{"Bottom", "-", 
       RowBox[{"left", " ", "block"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"(*", 
      RowBox[{
       RowBox[{"block22", "=", 
        RowBox[{"blocks", "[", 
         RowBox[{"[", 
          RowBox[{"2", ",", "2"}], "]"}], "]"}]}], " ", ";"}], "*)"}], 
     RowBox[{"(*", 
      RowBox[{"Bottom", "-", 
       RowBox[{"right", " ", "block"}]}], "*)"}], "\[IndentingNewLine]", 
     RowBox[{"ret", "=", 
      RowBox[{
       RowBox[{"ArrayFlatten", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"blocks", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"blocks", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"blocks", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"blocks", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "2"}], "]"}], "]"}]}], "}"}]}], "}"}], "]"}], 
       " ", "===", " ", "mat"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"If", "[", 
      RowBox[{"ret", ",", 
       RowBox[{"Return", "[", 
        RowBox[{"{", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{
            RowBox[{"blocks", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"blocks", "[", 
             RowBox[{"[", 
              RowBox[{"1", ",", "2"}], "]"}], "]"}]}], "}"}], ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"blocks", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "1"}], "]"}], "]"}], ",", 
            RowBox[{"blocks", "[", 
             RowBox[{"[", 
              RowBox[{"2", ",", "2"}], "]"}], "]"}]}], "}"}]}], "}"}], "]"}], 
       ",", 
       RowBox[{
        RowBox[{"##", "&"}], "[", "]"}]}], "]"}], ";", "\[IndentingNewLine]", 
     
     RowBox[{"Return", "[", "Null", "]"}], ";"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.973763997422471*^9, 3.9737640073984957`*^9}, {
