Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "Helper", " ", "to", " ", "perform", " ", "one", " ", "pass", " ", "of", " ",
     "merging"}], " ", "*)"}], "\[IndentingNewLine]", 
  RowBox[{Cell[TextData[{
    Cell[BoxData[
     RowBox[{
      TemplateBox[{
        Cell[
         TextData["Delete"]], "paclet:ref/Delete"},
       "RefLink",
       BaseStyle->{"InlineFormula"}], "[", 
      RowBox[{
       StyleBox["expr", "TI"], ",", 
       RowBox[{"{", 
        RowBox[{
         StyleBox["i", "TI"], ",", 
         StyleBox["j", "TI"], ",", 
         StyleBox["\[Ellipsis]", "TR"]}], "}"}]}], "]"}]], "InlineFormula",
     FontFamily->"Source Sans Pro",ExpressionUUID->
     "3d0acbed-16f2-4185-a8d5-61c762a80ab3"],
    "  deletes the part at position ",
    Cell[BoxData[
     RowBox[{"{", 
      RowBox[{
       StyleBox["i", "TI"], ",", 
       StyleBox["j", "TI"], ",", 
       StyleBox["\[Ellipsis]", "TR"]}], "}"}]], "InlineFormula",
     FontFamily->"Source Sans Pro",ExpressionUUID->
     "4d3e23a2-d4ed-441a-9009-743f6a1d528f"],
    ". "
   }], "Text",ExpressionUUID->"781e7949-6ff7-41df-886d-a79e78426bf7"], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"MergeSetsStep", "[", "currentSets_List", "]"}], " ", ":=", " ", 
     
     RowBox[{"Module", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"i", ",", " ", "j", ",", 
         RowBox[{"n", " ", "=", " ", 
          RowBox[{"Length", "[", "currentSets", "]"}]}], ",", "  ", 
         RowBox[{"merged", " ", "=", " ", "currentSets"}]}], "}"}], ",", "\n",
        "  ", 
       RowBox[{"(*", " ", 
        RowBox[{
        "We", " ", "look", " ", "for", " ", "the", " ", "first", " ", "pair", 
         " ", 
         RowBox[{"(", 
          RowBox[{"i", ",", " ", "j"}], ")"}], " ", "that", " ", 
         "intersects"}], " ", "*)"}], "\n", "  ", 
       RowBox[{"Catch", "[", "\n", "    ", 
        RowBox[{
         RowBox[{"For", "[", 
          RowBox[{
           RowBox[{"i", " ", "=", " ", "1"}], ",", " ", 
           RowBox[{"i", " ", "<=", " ", 
            RowBox[{"Length", "[", "merged", "]"}]}], ",", " ", 
           RowBox[{"i", "++"}], ",", "\n", "      ", 
           RowBox[{
            RowBox[{"For", "[", 
             RowBox[{
              RowBox[{"j", " ", "=", " ", 
               RowBox[{"i", " ", "+", " ", "1"}]}], ",", " ", 
              RowBox[{"j", " ", "<=", " ", 
               RowBox[{"Length", "[", "merged", "]"}]}], ",", " ", 
              RowBox[{"j", "++"}], ",", "\n", "         ", 
              RowBox[{
               RowBox[{"If", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"Intersection", "[", 
                   RowBox[{
                    RowBox[{"merged", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], ",", " ", 
                    RowBox[{"merged", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], "]"}], " ", "=!=", " ", 
                  
                  RowBox[{"{", "}"}]}], ",", "\n", "            ", 
                 RowBox[{"(*", " ", 
                  RowBox[{"Found", " ", 
                   RowBox[{"intersection", ":", " ", 
                    RowBox[{"Merge", " ", "and", " ", "Throw", " ", "to", " ", 
                    RowBox[{"restart", "/", "finish"}], " ", "this", " ", 
                    "step"}]}]}], " ", "*)"}], "\n", "            ", 
                 RowBox[{
                  RowBox[{"merged", " ", "=", " ", 
                   RowBox[{"Delete", "[", 
                    RowBox[{"merged", ",", " ", 
                    RowBox[{"{", 
                    RowBox[{
                    RowBox[{"{", "i", "}"}], ",", " ", 
                    RowBox[{"{", "j", "}"}]}], "}"}]}], "]"}]}], ";", "\n", 
                  "            ", 
                  RowBox[{"AppendTo", "[", 
                   RowBox[{"merged", ",", " ", 
                    RowBox[{"Sort", "[", 
                    RowBox[{"Union", "[", 
                    RowBox[{
                    RowBox[{"currentSets", "[", 
                    RowBox[{"[", "i", "]"}], "]"}], ",", " ", 
                    RowBox[{"currentSets", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], "]"}], "]"}]}], "]"}], ";",
                   "\n", "            ", 
                  RowBox[{"Throw", "[", 
                   RowBox[{"Sort", "[", "merged", "]"}], "]"}], ";"}]}], " ", 
                
                RowBox[{"(*", " ", 
                 RowBox[{"Sort", " ", "for", " ", "canonical", " ", "form"}], 
                 " ", "*)"}], "\n", "         ", "]"}], ";"}]}], "\n", 
             "      ", "]"}], ";"}]}], "\n", "    ", "]"}], ";", "\n", "    ", 
         RowBox[{"(*", " ", 
          RowBox[{
           RowBox[{"If", " ", "no", " ", "intersection", " ", "found"}], ",", 
           " ", 
           RowBox[{"return", " ", "original", " ", "sorted"}]}], " ", "*)"}], 
         "\n", "    ", 
         RowBox[{"Sort", "[", "merged", "]"}]}], "\n", "  ", "]"}]}], "\n", 
      "]"}]}], ";"}]}]}]], "Input",
 CellChangeTimes->{
  3.978888533172289*^9, {3.983794480559291*^9, 3.98379448570045*^9}, {
   3.983794631235962*^9, 3.983794655276204*^9}},
 Background->RGBColor[1., 0.9974670023651484, 0.],
 CellLabel->"In[21]:=",ExpressionUUID->"2f981685-9729-42a9-9961-b80ba17feaa4"],

