Cell[BoxData[{
 RowBox[{
  RowBox[{"Clear", "[", "safeInverse", "]"}], ";"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"safeInverse", "[", 
    RowBox[{"m_", "?", "MatrixQ"}], "]"}], " ", ":=", " ", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"a", ",", " ", "b"}], "}"}], ",", "\n", "   ", 
     RowBox[{
      RowBox[{
       RowBox[{"{", 
        RowBox[{"a", ",", " ", "b"}], "}"}], " ", "=", " ", 
       RowBox[{"Dimensions", "[", "m", "]"}]}], ";", "\n", "    ", 
      RowBox[{"Catch", "[", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"a", " ", "!=", " ", "b"}], ",", " ", 
         RowBox[{"Throw", "[", 
          RowBox[{"Return", "[", 
           RowBox[{"{", 
            RowBox[{"a", ",", " ", "b"}], "}"}], "]"}], "]"}], ",", 
         RowBox[{
          RowBox[{"##", "&"}], "[", "]"}]}], "]"}], "]"}], ";", "\n", "   ", 
      RowBox[{"Catch", "[", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{
          RowBox[{"Det", "[", "m", "]"}], " ", "==", " ", "0"}], ",", " ", 
         RowBox[{
          RowBox[{"Throw", "[", 
           RowBox[{"Return", "[", "\"\<Error: Singular Matrix\>\"", "]"}], 
           "]"}], ";"}], ",", 
         RowBox[{
          RowBox[{"##", "&"}], "[", "]"}]}], "]"}], "]"}], ";", "\n", "   ", 
      RowBox[{"Return", "[", " ", 
       RowBox[{"Inverse", "[", "m", "]"}], "]"}], ";"}]}], "]"}]}], 
  ";"}]}], "Input",
 CellChangeTimes->{{3.980334206576359*^9, 3.9803342114346867`*^9}, {
