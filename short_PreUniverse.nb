        TagBox[
         RowBox[{"(", 
          RowBox[{"0", ",", "1"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"z", ",", "t"}], "]"}], "\[Equal]", 
      RowBox[{
       RowBox[{"-", 
        FractionBox[
         RowBox[{"2", " ", "M", " ", 
          RowBox[{
           RowBox[{"yZ", "[", "14", "]"}], "[", 
           RowBox[{"z", ",", "t"}], "]"}]}], "H"]}], "-", 
       RowBox[{"6", " ", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"yZ", "[", "12", "]"}], 
          TagBox[
           RowBox[{"(", 
            RowBox[{"1", ",", "0"}], ")"}],
           Derivative],
          MultilineFunction->None], "[", 
         RowBox[{"z", ",", "t"}], "]"}]}]}]}], ",", 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        RowBox[{"yZ", "[", "14", "]"}], 
        TagBox[
         RowBox[{"(", 
          RowBox[{"0", ",", "1"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"z", ",", "t"}], "]"}], "\[Equal]", 
      RowBox[{
       FractionBox[
        RowBox[{"2", " ", "M", " ", 
         RowBox[{
          RowBox[{"yZ", "[", "13", "]"}], "[", 
          RowBox[{"z", ",", "t"}], "]"}]}], "H"], "+", 
       RowBox[{"6", " ", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"yZ", "[", "15", "]"}], 
          TagBox[
           RowBox[{"(", 
            RowBox[{"1", ",", "0"}], ")"}],
           Derivative],
          MultilineFunction->None], "[", 
         RowBox[{"z", ",", "t"}], "]"}]}]}]}], ",", 
     RowBox[{
      RowBox[{
       SuperscriptBox[
        RowBox[{"yZ", "[", "15", "]"}], 
        TagBox[
         RowBox[{"(", 
          RowBox[{"0", ",", "1"}], ")"}],
         Derivative],
        MultilineFunction->None], "[", 
       RowBox[{"z", ",", "t"}], "]"}], "\[Equal]", 
      RowBox[{
       FractionBox[
        RowBox[{"2", " ", "M", " ", 
         RowBox[{
          RowBox[{"yZ", "[", "12", "]"}], "[", 
          RowBox[{"z", ",", "t"}], "]"}]}], "H"], "+", 
       RowBox[{"6", " ", 
        RowBox[{
         SuperscriptBox[
          RowBox[{"yZ", "[", "14", "]"}], 
          TagBox[
           RowBox[{"(", 
            RowBox[{"1", ",", "0"}], ")"}],
           Derivative],
          MultilineFunction->None], "[", 
         RowBox[{"z", ",", "t"}], "]"}]}]}]}]}], "}"}], ",", 
   RowBox[{"{", 
    RowBox[{
     RowBox[{
      RowBox[{"yZ", "[", "12", "]"}], "[", 
      RowBox[{"z", ",", "t"}], "]"}], ",", 
