Cell[TextData[{
 StyleBox["two   7 - planes ,  each  dual to  vectorFormOfType2, \
vectorFormOfType1, respectively;\n intersection of planes , if not parallel, \
yields a  6-plane  ",
  FontSize->18],
 Cell[BoxData[
  FormBox[
   SuperscriptBox["M", "6"], TraditionalForm]],
  FontSize->18,ExpressionUUID->"8cd6a95e-949a-41c1-a5c6-6e1e79285266"],
 StyleBox["\nremember, one",
  FontSize->18],
 " ",
 Cell[BoxData[
