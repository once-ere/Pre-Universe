Cell[BoxData[
 RowBox[{
  RowBox[{"makeAntiSym", "[", 
   RowBox[{"size_", ",", "fn_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "rtmp", "}"}], ",", 
    RowBox[{
     RowBox[{"rtmp", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"i", "\[Equal]", " ", "j"}], ",", "0", ",", 
          RowBox[{"fn", "[", 
           RowBox[{"i", ",", "j"}], "]"}]}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"i", ",", "1", ",", "size"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"j", ",", "1", ",", "i"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"MapThread", "[", 
      RowBox[{"Join", ",", 
       RowBox[{"{", 
        RowBox[{"rtmp", ",", 
         RowBox[{"Rest", "/@", 
          RowBox[{"Flatten", "[", 
           RowBox[{
            RowBox[{"-", "rtmp"}], ",", 
            RowBox[{"{", 
             RowBox[{
              RowBox[{"{", "2", "}"}], ",", 
              RowBox[{"{", "1", "}"}]}], "}"}]}], "]"}]}]}], "}"}]}], 
      "]"}]}]}], "]"}]}]], "Input",
