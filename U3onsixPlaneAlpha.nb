         RowBox[{"0", ",", "0", ",", "0", ",", "0", ",", 
          RowBox[{"-", "1"}], ",", "0"}], "}"}]}], "}"}]}], 
     ",", "\<\"True (VERIFIED)\"\>", ",", "\<\"ERROR\"\>"}], "]"}]}],
