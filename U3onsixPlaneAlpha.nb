Cell[CellGroupData[{

Cell["Section 6: The K\[ADoubleDot]hler Form omega on sixPlaneAlpha", \
"Section",
 CellChangeTimes->{
  3.983564832025402*^9},ExpressionUUID->"33d46f51-7de0-49d1-9910-\
791a764a3864"],

Cell["\<\
Given the metric g and the almost-complex structure J, the K\[ADoubleDot]hler \
(fundamental) 2-form omega is defined by:

  omega(X,Y) = g(JX, Y)

for any tangent vectors X, Y on sixPlaneAlpha. As a 6x6 matrix:
  omega_{ij} = omega(e_i, e_j) = g(J e_i, e_j) = sum_k J_{ki} g_{kj} = (J^T . \
g)_{ij}.
With g = Identity this gives omega = J^T = -J (since j2^T = -j2).\
\>", "Text",ExpressionUUID->"681884ef-5ed8-4175-95d6-22d8e93323dd"],

Cell[CellGroupData[{

Cell["\<\
(* ---- Define the K\[ADoubleDot]hler form omega ---- *)

(* omega_{ij} = g(J e_i, e_j) = sum_k J_{ki} g_{kj} = (J^T . g)_{ij} *)
(* With g = Identity: omega = J^T = -J (since j2^T = -j2) *)
omega6 = Transpose[J6] . g6;
Print[\"K\[CapitalATilde]\[Currency]hler form omega on sixPlaneAlpha:\"];
Print[MatrixForm[omega6]];

(* Verify antisymmetry: omega^T = -omega *)
Print[\"omega is antisymmetric: \", If[Transpose[omega6] == -omega6, \"True \
(VERIFIED)\", \"ERROR\"]];

(* Verify non-degeneracy: det(omega) != 0 *)
detOmega = Det[omega6];
Print[\"det(omega) = \", detOmega, \"  (non-degenerate: \", If[detOmega != 0, \
\"True\", \"False\"], \")\"];

(* The top power omega^3 should be a volume form (non-zero multiple of the \
volume element) *)
omega3 = omega6 . omega6 . omega6;
Print[\"omega^3 = \", If[Det[omega3] != 0, \"non-zero (volume form \
VERIFIED)\", \"ERROR: degenerate\"]];\
\>", "Input",
 CellLabel->
  "In[407]:=",ExpressionUUID->"944fc9a5-dae5-4da2-a018-344a8a0a2b6b"],

Cell[CellGroupData[{

Cell[BoxData["\<\"K\[CapitalATilde]\[Currency]hler form omega on \
