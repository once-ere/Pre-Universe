Cell[CellGroupData[{

Cell["Section 10: SU(3) Commutation Relations", "Section",ExpressionUUID->"78830af9-3710-41b6-8ee0-3b1b225c1b5c"],

Cell["\<\
The SU(3) generators satisfy the Lie algebra commutation relations:

  [lambda_a, lambda_b] = 2i sum_c f_{abc} lambda_c

where f_{abc} are the SU(3) structure constants (totally antisymmetric). Some \
key relations:
  [lambda_1, lambda_2] = 2i lambda_3
  [lambda_4, lambda_5] = i lambda_3 + i sqrt(3) lambda_8
  [lambda_6, lambda_7] = i lambda_8 * sqrt(3) - i lambda_3

In the real 6x6 representation, these become (with the i -> j2 substitution).\
\
\>", "Text",ExpressionUUID->"2d26a601-8d49-4d1d-ba99-74bb43a21523"],

Cell[CellGroupData[{

Cell["\<\
(* ---- Verify sample commutation relations in real 6x6 representation ---- *)

(* In the real representation, complex multiplication by i is replaced by the \
matrix j2 = {{0,-1},{1,0}} *)
(* Thus [lambda_a, lambda_b] = 2 * realRep6[i * lambda_c] = 2 * realRep6[i] . \
realRep6[lambda_c] etc. *)
(* We check the structure constants directly from the commutators. *)

comm12 = lam[[1]] . lam[[2]] - lam[[2]] . lam[[1]];
(* [lambda_1, lambda_2] = 2i lambda_3 in complex representation.              \
*)
(* In real rep: realRep6[2i lambda_3] = 2 * KroneckerProduct[lam3c, j2]      *)
(* since lam3c is real (diagonal): Im[i*lam3c] = lam3c, Re[i*lam3c] = 0.    \
*)
comm12expected = 2 * realRep6[I * lam3c];
Print[\"[lambda_1, lambda_2] = 2i lambda_3 (real rep): \",
  If[Chop[comm12] == Chop[comm12expected], \"VERIFIED\",
     \"Checking numerically: \", Chop[comm12 - comm12expected]]];

(* Check [lambda_3, lambda_4] = -2i lambda_5, i.e., = -2 realRep(i) lambda_5 *)
comm34 = lam[[3]] . lam[[4]] - lam[[4]] . lam[[3]];
Print[\"[lambda_3, lambda_4] computed:\"];
Print[MatrixForm[Chop[comm34]]];

(* Check that all commutators stay within the span of \
{lambda_1,...,lambda_8,J} *)
Print[\"\\nSample commutator [lambda_1, lambda_2]:\"];
Print[MatrixForm[Chop[comm12]]];\
\>", "Input",
 CellLabel->
  "In[509]:=",ExpressionUUID->"b58f0109-b39c-416b-ae85-73b51065e9d6"],

Cell[CellGroupData[{

Cell[BoxData[
 InterpretationBox[
  RowBox[{"\<\"[lambda_1, lambda_2] = 2i lambda_3 (real rep): \"\>", 
   "\[InvisibleSpace]", "\<\"VERIFIED\"\>"}],
  SequenceForm["[lambda_1, lambda_2] = 2i lambda_3 (real rep): ", "VERIFIED"],
  
  Editable->False]], "Print",
 CellChangeTimes->{3.983564413951599*^9, 3.983564776385494*^9},
 CellLabel->
